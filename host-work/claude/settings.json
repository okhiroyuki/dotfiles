{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "enabledPlugins": {
    "crit@crit": true,
    "product-skills@claude-code-skills": true,
    "skill-scanner@skillplugs": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    },
    "claude-code-skills": {
      "source": {
        "source": "github",
        "repo": "alirezarezvani/claude-skills"
      }
    },
    "skillplugs": {
      "source": {
        "source": "github",
        "repo": "skillplugs/plugins"
      }
    }
  },
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(gh gist list *)",
      "Bash(gh gist view *)",
      "Bash(gh label list *)",
      "Bash(gh api *)",
      "Bash(gh search *)",
      "Bash(brew search *)",
      "Bash(brew info *)",
      "Bash(gh browse*)",
      "Bash(gh status*)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git blame *)",
      "Bash(git tag *)",
      "Bash(git remote -v *)",
      "Bash(git remote show *)",
      "Bash(git config --get *)",
      "Bash(git config --list *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git rev-parse *)",
      "Bash(git describe *)",
      "Bash(git shortlog *)",
      "Bash(man *)",
      "Bash(rcup --help *)",
      "Bash(lsrc *)",
      "Bash(col *)",
      "Bash(grep *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git cherry-pick *)",
      "Bash(crit *)",
      "Bash(scapple *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(tr *)",
      "Bash(cat *)",
      "Bash(ps *)",
      "Bash(date *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(readlink *)",
      "Bash(cd *)",
      "Bash(* --version*)",
      "Bash(* --help*)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "WebFetch(domain:crit.md)"
    ],
    "deny": [
      "Bash(pup * delete*)",
      "Bash(pup * create*)",
      "Bash(pup * update*)",
      "Bash(pup * cancel*)",
      "Bash(pup * disable*)",
      "Bash(pup * revoke*)",
      "Bash(pup * publish*)",
      "Bash(pup * archive*)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git tag -d *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(pup auth logout*)"
    ]
  }
}
