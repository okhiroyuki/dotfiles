{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "theme": "dark",
  "enabledPlugins": {
    "crit@crit": true,
    "product-skills@claude-code-skills": true,
    "skill-scanner@skillplugs": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    },
    "claude-code-skills": {
      "source": {
        "source": "github",
        "repo": "alirezarezvani/claude-skills"
      }
    },
    "skillplugs": {
      "source": {
        "source": "github",
        "repo": "skillplugs/plugins"
      }
    }
  },
  "permissions": {
    "allow": [
      // ===== GitHub CLI (gh) =====
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(gh gist list *)",
      "Bash(gh gist view *)",
      "Bash(gh label list *)",
      "Bash(gh api *)",
      "Bash(gh search *)",
      "Bash(gh browse *)",
      "Bash(gh status *)",
      // ===== Homebrew =====
      "Bash(brew search *)",
      "Bash(brew info *)",
      // ===== Git (読み取り専用) =====
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git blame *)",
      "Bash(git tag *)",
      "Bash(git remote -v *)",
      "Bash(git remote show *)",
      "Bash(git config --get *)",
      "Bash(git config --list *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git rev-parse *)",
      "Bash(git describe *)",
      "Bash(git shortlog *)",
      // ===== Git (変更を伴う操作) =====
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git cherry-pick *)",
      // ===== その他ツール =====
      "Bash(crit *)",
      "Bash(scapple *)",
      // ===== 汎用コマンド(読み取り専用) =====
      "Bash(man *)",
      "Bash(col *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(tr *)",
      "Bash(cat *)",
      "Bash(ps *)",
      "Bash(date *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(readlink *)",
      "Bash(cd *)",
      // ===== フラグ =====
      "Bash(* --version*)",
      "Bash(* --help*)",
      // ===== Skill =====
      "Skill(update-config)",
      "Skill(update-config:*)",
      // ===== WebFetch: crit =====
      "WebFetch(domain:crit.md)",
      // ===== Anthropic / Claude =====
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      // ===== GitHub =====
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      // ===== Renovate ====
      "WebFetch(domain:docs.renovatebot.com)",
      // ===== 技術ドキュメント =====
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:kubernetes.io)",
      // ===== npm / パッケージ管理 =====
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:pnpm.io)",
      // ===== シェル / 開発環境ツール =====
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:direnv.net)",
      "WebFetch(domain:dprint.dev)",
      // ===== Homebrew =====
      "WebFetch(domain:formulae.brew.sh)",
      "WebFetch(domain:docs.brew.sh)",
      // ===== Git =====
      "WebFetch(domain:git-scm.com)"
    ],
    "deny": [
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git tag -d *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "ask": [
      "Bash(git push *)"
    ]
  }
}
